{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "fonts/**/*",
        "outDir": "dist/fonts",
        "watchAssets": true
      }
    ],
    "deleteOutDir": true
  }
}